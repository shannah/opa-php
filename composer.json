{
    "name": "opa/opa-php",
    "description": "PHP library for generating and reading Open Prompt Archive (OPA) files",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Steve Hannah",
            "email": "steve@weblite.ca"
        }
    ],
    "keywords": ["opa", "open-prompt-archive", "prompt", "archive", "ai"],
    "homepage": "https://github.com/shannah/opa-php",
    "support": {
        "issues": "https://github.com/shannah/opa-php/issues",
        "source": "https://github.com/shannah/opa-php"
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "ext-zip": "*",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "OPA\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OPA\\Tests\\": "tests/"
        }
    }
}
