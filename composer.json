{
    "name": "opa/opa-php",
    "description": "PHP library for generating and reading Open Prompt Archive (OPA) files",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "ext-zip": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "OPA\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OPA\\Tests\\": "tests/"
        }
    }
}
